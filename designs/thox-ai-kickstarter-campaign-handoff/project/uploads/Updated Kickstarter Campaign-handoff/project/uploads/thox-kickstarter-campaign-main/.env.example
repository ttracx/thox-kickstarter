# Thox.ai campaign automation environment.
# Copy to .env and fill in for live runs only. Tests and the mock pipeline never
# require these values.

# Anthropic API key, used only by `cli.py run --live` and the AnthropicLLM client.
ANTHROPIC_API_KEY=

# Optional override for the default model used by live agent runs.
# Defaults are defined per agent in config/agents.yaml.
# THOX_DEFAULT_MODEL=claude-sonnet-4-6
